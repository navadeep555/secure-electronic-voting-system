[req]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
x509_extensions    = v3_req

[dn]
C  = IN
ST = Telangana
L  = Hyderabad
O  = Secure Electronic Voting System
OU = DevOps
CN = localhost

[v3_req]
subjectAltName = @alt_names
keyUsage       = nonRepudiation, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = localhost
DNS.2 = voting.local
DNS.3 = *.voting.local
IP.1  = 127.0.0.1
IP.2  = 0.0.0.0
