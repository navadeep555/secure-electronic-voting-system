{
    "rewrites": [
        {
            "source": "/api/votes/:match*",
            "destination": "https://voting-core.onrender.com/api/votes/:match*"
        },
        {
            "source": "/api/:match*",
            "destination": "https://flask-backend-wm4y.onrender.com/api/:match*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}