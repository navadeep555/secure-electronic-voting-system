# ==============================================================
# .env.example – Environment Variable Template
# Secure Electronic Voting System – Deployment Config
# ==============================================================
# USAGE:
#   cp .env.example .env
#   # Edit .env with your actual secrets
#   # NEVER commit .env to version control!
# ==============================================================

# ── Application Secrets ────────────────────────────────────────
# JWT signing secret – CHANGE THIS before production!
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_THIS_JWT_SECRET_IN_PRODUCTION

# Database integrity HMAC key
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
DB_INTEGRITY_KEY=CHANGE_THIS_INTEGRITY_KEY_IN_PRODUCTION

# ── Flask Backend ──────────────────────────────────────────────
FLASK_ENV=production
# FLASK_DEBUG=0           # Never enable debug in production!

# ── Node.js Voting Core ────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── PostgreSQL Database ────────────────────────────────────────
# Must match POSTGRES_* values in docker-compose.yml
DB_HOST=postgres
DB_USER=voting
DB_PASSWORD=voting123
DB_NAME=votingdb
DB_PORT=5432

# ── Domain Configuration ───────────────────────────────────────
# For Let's Encrypt: set to your actual domain
DOMAIN=localhost
# DOMAIN=yourvotingapp.com

# ── Let's Encrypt (production only) ───────────────────────────
# CERTBOT_EMAIL=admin@yourvotingapp.com

# ── CORS (adjust for production domain) ───────────────────────
# The existing app.py has CORS set to http://localhost:8080
# In production this should be your actual frontend domain
# (No code change needed – configure via env if supported by app)
# ALLOWED_ORIGINS=https://yourvotingapp.com

# ── Database Paths (inside containers) ────────────────────────
FLASK_DB_PATH=/app/voting_system.db
VOTING_CORE_DB_PATH=/app/data/voting_core.db
