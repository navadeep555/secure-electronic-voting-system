{
  "rewrites": [
    {
      "source": "/api/votes/:match*",
      "destination": "https://YOUR_VOTING_CORE_RENDER_URL_HERE.onrender.com/api/votes/:match*"
    },
    {
      "source": "/api/:match*",
      "destination": "https://YOUR_FLASK_BACKEND_RENDER_URL_HERE.onrender.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
